# ─── 필수 ─────────────────────────────────────
NOTION_TOKEN=
NOTION_ROOT_DB_ID=
ANTHROPIC_API_KEY=

# ─── 텔레그램 봇 (선택) ─────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# ─── 디스코드 봇 (선택) ─────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_CHANNEL_ID=
DISCORD_WEBHOOK_URL=

# ─── YouTube (선택) ─────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNELS=                # 콤마 구분 채널 ID (예: UCxxxx,UCyyyy)

# ─── 구독 계정 (선택) ──────────────────────────
THREADS_ACCOUNTS=                # 콤마 구분 (예: jaykimuniverse,username2)
INSTAGRAM_ACCOUNTS=              # 콤마 구분 (예: username1,username2)

# ─── 서버 설정 (선택) ──────────────────────────
PORT=3000
NODE_ENV=production
SCHEDULE_TIMES=09:00,14:00,19:00,23:00

# ─── 멀티모달 분석 (선택) ────────────────────────
MULTIMODAL_ENABLED=true          # false로 설정하면 텍스트만 분석
MAX_IMAGES_PER_ANALYSIS=5        # 분석에 포함할 최대 이미지 수

# ─── 확장프로그램 API (선택) ─────────────────────
API_KEY=                         # 확장프로그램 인증용 API 키

# ─── Puppeteer (배포 환경) ──────────────────────
CHROMIUM_PATH=                   # Railway/Render에서 Chromium 경로
